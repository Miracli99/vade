{
  "name": "vade-retro-companion",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export -p web --output-dir dist",
    "docker:build": "docker build -t vade-retro-web .",
    "docker:run": "docker run --rm -p 8080:80 vade-retro-web",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~53.0.9",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.10",
    "expo-image-picker": "~16.1.4",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "typescript": "^5.8.3"
  }
}
