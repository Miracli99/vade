{
  "name": "vade-retro-companion",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "android:release": "set NODE_ENV=production&& cd android && gradlew.bat assembleRelease",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "generate:image-library": "node scripts/generate-image-library.js",
    "export:web": "expo export -p web --output-dir dist",
    "docker:build": "docker build -t vade-retro-web .",
    "docker:run": "docker run --rm -p 8080:80 vade-retro-web",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "babel-preset-expo": "~56.0.0",
    "expo": "^56.0.0",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-image-picker": "~56.0.15",
    "expo-sharing": "~56.0.15",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "jszip": "^3.10.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
